{
  "name": "pr-dashboard-tests",
  "private": true,
  "scripts": {
    "test": "node test-pr-filters.js",
    "test:extended": "node test-pr-extended.js",
    "test:all": "node -e \"const {spawnSync}=require('child_process');const r=s=>spawnSync(process.platform==='win32'?'npm.cmd':'npm',['run',s],{stdio:'inherit'});const a=r('test'),b=r('test:extended');process.exit((a.status||0)!==0||(b.status||0)!==0?1:0);\""
  },
  "devDependencies": {
    "playwright": "^1.59.1"
  }
}
